<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Prácticas Parcial 2"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="30dp"/>

    <Button
        android:id="@+id/btnPractica1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Práctica 1: Distancia entre Puntos"
        android:layout_marginBottom="15dp"/>

    <Button
        android:id="@+id/btnPractica2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Práctica 2: Triángulos"
        android:layout_marginBottom="15dp"/>

    <Button
        android:id="@+id/btnPractica3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Práctica 3: Datos Personales y Zodiaco"
        android:layout_marginBottom="15dp"/>

    <Button
        android:id="@+id/btnPractica4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Práctica 4: Valor de resistencias"
        android:layout_marginBottom="15dp"/>

    <Button
        android:id="@+id/btnPractica5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Práctica 5: Cinepolis"/>
</LinearLayout>